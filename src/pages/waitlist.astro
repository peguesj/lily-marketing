---
import BaseLayout from '../layouts/BaseLayout.astro';
import Illustration from '../components/Illustration.tsx';
---

<BaseLayout
  title="Join the Waitlist — Lily | Be First to Experience Identity-Aware Care"
  description="Lily is launching soon. Join the waitlist to get early access to identity-aware therapy matching, AI-assisted wellness tools, and a platform built for all three sides."
  canonical="https://www.asklily.health/waitlist"
  keywords="Lily waitlist, early access therapy platform, mental health beta, identity-aware matching waitlist"
>
  <main>
    <section class="page-hero">
      <div class="container wide">
        <div class="page-hero-grid">
          <div>
            <div class="hero-eyebrow"><span class="dot"></span>Early access</div>
            <h1>Be first in line for <em>care that fits</em>.</h1>
            <p>
              Lily is launching soon. Drop your email and we'll let you know the moment your side of the platform is ready —
              whether you're seeking care, providing it, or paying for it.
            </p>

            <form id="waitlist-form" class="waitlist-form" style="margin-top: 2rem;">
              <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 440px;">
                <label for="wl-role" class="sr-only">I am a</label>
                <select id="wl-role" name="role" required style="padding: 14px 16px; border-radius: 14px; border: 1.5px solid hsla(145, 30%, 60%, 0.35); background: hsla(43, 35%, 97%, 0.85); font-family: var(--sans); font-size: 1rem;">
                  <option value="">I am a...</option>
                  <option value="member">Member seeking care</option>
                  <option value="practitioner">Practitioner / clinician</option>
                  <option value="organization">Organization / employer</option>
                </select>

                <label for="wl-email" class="sr-only">Email address</label>
                <input
                  id="wl-email"
                  name="email"
                  type="email"
                  required
                  placeholder="your@email.com"
                  style="padding: 14px 16px; border-radius: 14px; border: 1.5px solid hsla(145, 30%, 60%, 0.35); background: hsla(43, 35%, 97%, 0.85); font-family: var(--sans); font-size: 1rem;"
                />

                <button type="submit" class="btn primary" style="justify-content: center;">
                  Join the waitlist
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </div>

              <p id="wl-success" style="display: none; margin-top: 1.25rem; color: hsl(145, 60%, 26%); font-weight: 500;">
                You're on the list! We'll be in touch soon.
              </p>
            </form>
          </div>
          <div class="page-hero-illust-wrap">
            <Illustration client:load n={3} size={300} alt="Growing together" />
          </div>
        </div>
      </div>
    </section>

    <section class="section cream">
      <div class="container narrow" style="text-align: center;">
        <div class="section-head center">
          <div class="section-eyebrow">What's coming</div>
          <h2 class="section-title">Three products. One platform.</h2>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-top: 2rem;">
          <div>
            <h4 style="color: hsl(145, 60%, 26%);">Lily Match</h4>
            <p style="font-size: 0.95rem;">Identity-aware therapy matching for members and families.</p>
          </div>
          <div>
            <h4 style="color: hsl(145, 60%, 26%);">Lily Practice</h4>
            <p style="font-size: 0.95rem;">All-in-one practice management for clinicians.</p>
          </div>
          <div>
            <h4 style="color: hsl(145, 60%, 26%);">Lily Admin</h4>
            <p style="font-size: 0.95rem;">Outcomes-tracked mental health benefit for organizations.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const success = document.getElementById('wl-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // For now, just show success — backend integration TBD
    if (success) success.style.display = 'block';
    form.querySelectorAll('input, select, button').forEach((el) => {
      (el as HTMLInputElement | HTMLButtonElement | HTMLSelectElement).disabled = true;
    });
  });
</script>
