---
import BaseLayout from '../layouts/BaseLayout.astro';
import Orbit from '../components/Orbit.tsx';
import Btn from '../components/Btn.tsx';
import TrustStrip from '../components/TrustStrip.tsx';
import LogoStrip from '../components/LogoStrip.tsx';
import CTABand from '../components/CTABand.tsx';
import Icon from '../components/Icon.tsx';
import content from '../content/pages/index.json';

const productSection = content.sections.find(s => s.id === 'products')!;
const matchSection = content.sections.find(s => s.id === 'match')!;
const outcomesSection = content.sections.find(s => s.id === 'outcomes')!;
const logosSection = content.sections.find(s => s.id === 'logos')!;
---

<BaseLayout
  title={content.title}
  description={content.description}
  canonical="https://www.asklily.health/"
  keywords={content.keywords}
>
  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container wide">
        <div class="hero-grid">
          <div>
            <div class="hero-eyebrow">
              <span class="dot"></span>
              {content.heroEyebrow}
            </div>
            <h1 set:html={content.heroTitle} />
            <p class="hero-sub" set:html={content.heroSubtitle} />
            <div class="hero-actions">
              <Btn client:load kind="primary" size="lg" href="/members" icon="arrow">Find your match</Btn>
              <Btn client:load kind="ghost" size="lg" href="/how">See how Lily works</Btn>
            </div>
            <div class="hero-trust">
              {content.heroTrustItems.map(item => (
                <span class="hero-trust-item"><Icon name={item.icon} /> {item.text}</span>
              ))}
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-orbit-stage">
              <div class="center-orbit">
                <Orbit
                  client:load
                  size={320}
                  initials="MR"
                  avatarTone="peach"
                  image="/assets/avatar-mr.jpg"
                  badges={[
                    { key: "trauma",   label: "Trauma-informed",    tone: "trauma",   icon: "shield",   angle: 30  },
                    { key: "bipoc",    label: "BIPOC clinician",     tone: "bipoc",    icon: "users",    angle: 90  },
                    { key: "language", label: "EN · ES",             tone: "language", icon: "language", angle: 150 },
                    { key: "lgbtq",    label: "LGBTQIA+ affirming",  tone: "lgbtq",    icon: "heart",    angle: 210 },
                    { key: "tele",     label: "Telehealth",          tone: "tele",     icon: "video",    angle: 270 },
                    { key: "sliding",  label: "Sliding scale",       tone: "sliding",  icon: "cash",     angle: 330 },
                  ]}
                />
              </div>
              <div class="floating-card fc-1">
                <span class="dot-mini"></span>
                <div>
                  <div class="text-pri">94% match</div>
                  <div class="text-sec">Identity-aligned</div>
                </div>
              </div>
              <div class="floating-card fc-2">
                <Icon name="calendar" size={16} />
                <div>
                  <div class="text-pri">Tue 4:00 PM</div>
                  <div class="text-sec">Open this week</div>
                </div>
              </div>
              <div class="floating-card fc-3">
                <Icon name="check" size={16} />
                <div>
                  <div class="text-pri">Lily Verified</div>
                  <div class="text-sec">Licensed in CA, NY</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST STRIP -->
    <section class="section compact" style="padding-top: 0;">
      <div class="container">
        <TrustStrip client:load />
      </div>
    </section>

    <!-- THREE PRODUCTS INTRO -->
    <section class="section cream">
      <div class="container wide">
        <div class="section-head center">
          <div class="section-eyebrow">{productSection.eyebrow}</div>
          <h2 class="section-title" set:html={productSection.heading} />
          <p class="section-sub">{productSection.body}</p>
        </div>
        <div class="feature-grid" style="margin-top: 48px;">
          {content.features.map(f => (
            <div class="feature">
              <div class="feature-icon"><Icon name={f.icon} size={22} /></div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
              <a href={f.link} class="feature-link">{f.linkText} &rarr;</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LILY MATCH SHOWCASE -->
    <section class="section">
      <div class="container wide">
        <div class="showcase">
          <div>
            <div class="section-eyebrow">{matchSection.eyebrow}</div>
            <h2 set:html={matchSection.heading} />
            <p>{matchSection.body}</p>
            <ul>
              {content.matchBullets.map(bullet => (
                <li><Icon name="check" /> {bullet}</li>
              ))}
            </ul>
            <div style="margin-top: 28px;">
              <Btn client:load kind="primary" href="/how" icon="arrow">See how Match works</Btn>
            </div>
          </div>
          <div>
            <div class="ui-frame">
              <div class="chrome">
                <div class="dot"></div><div class="dot"></div><div class="dot"></div>
                <div class="url">match.lilycare.co</div>
              </div>
              <div style="padding: 32px; background: linear-gradient(160deg, hsl(43 32% 96%), hsl(165 22% 93%));">
                <!-- Practitioner card — Jordan Kim -->
                <div class="pcard md" style="margin-bottom: 14px;">
                  <Orbit
                    client:load
                    size={104}
                    initials="JK"
                    avatarTone="teal"
                    image="/assets/avatar-jk.jpg"
                    badges={[
                      { key: "trauma",  tone: "trauma",   icon: "shield",   label: "Trauma",  angle: 45  },
                      { key: "lgbtq",   tone: "lgbtq",    icon: "heart",    label: "LGBTQ+",  angle: 140 },
                      { key: "tele",    tone: "tele",     icon: "video",    label: "Tele",    angle: 235 },
                      { key: "sliding", tone: "sliding",  icon: "cash",     label: "Sliding", angle: 320 },
                    ]}
                  />
                  <div class="body">
                    <div class="name">Jordan Kim, LMFT</div>
                    <div class="creds">She/her · Licensed in CA, OR · 8 yrs</div>
                    <div class="bio">Queer-affirming, somatic &amp; IFS. Specializes in trauma + identity work for first-gen Asian American clients.</div>
                    <div class="meta-row">
                      <span><Icon name="calendar" size={13} /> Tue 4pm open</span>
                      <span><Icon name="cash" size={13} /> $140 · sliding</span>
                      <span><Icon name="globe" size={13} /> CA, OR</span>
                    </div>
                  </div>
                  <div class="match">
                    <span class="lab">Match</span>
                    <b>94</b>
                    <span class="why">Identity · modality · open this week</span>
                    <button class="cta">Book intro</button>
                  </div>
                </div>
                <!-- Practitioner card — Dr. Maya Robinson -->
                <div class="pcard sm">
                  <Orbit
                    client:load
                    size={88}
                    initials="DR"
                    avatarTone="peach"
                    image="/assets/avatar-dr.jpg"
                    badges={[
                      { key: "bipoc",    tone: "bipoc",    icon: "users",    label: "BIPOC",  angle: 60  },
                      { key: "faith",    tone: "faith",    icon: "sparkle",  label: "Faith",  angle: 180 },
                      { key: "language", tone: "language", icon: "language", label: "EN/ES",  angle: 300 },
                    ]}
                  />
                  <div class="body">
                    <div class="name">Dr. Maya Robinson, PsyD</div>
                    <div class="creds">She/her · CA · 12 yrs</div>
                    <div class="meta-row">
                      <span><Icon name="calendar" size={13} /> Thu 11am</span>
                      <span><Icon name="cash" size={13} /> Aetna, BCBS</span>
                    </div>
                  </div>
                  <div class="match">
                    <span class="lab">Match</span>
                    <b>87</b>
                    <span class="why">Identity · insurance fit</span>
                    <button class="cta">Book intro</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OUTCOMES STATS -->
    <section class="section dark">
      <div class="container wide">
        <div class="section-head center">
          <div class="section-eyebrow">{outcomesSection.eyebrow}</div>
          <h2 class="section-title" style="color: hsl(43 30% 95%);" set:html={outcomesSection.heading} />
          <p class="section-sub">{outcomesSection.body}</p>
        </div>
        <div class="stat-row">
          {content.stats.map(s => (
            <div class="stat-big">
              <div class="num">{s.value}</div>
              <div class="lab">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TESTIMONIAL -->
    <section class="section">
      <div class="container narrow">
        <div class="testimonial">
          <blockquote>{content.testimonial.quote}</blockquote>
          <div class="quoted">
            <div class="lily-avatar lily-avatar-lg" style="width: 48px; height: 48px; border-radius: 50%; overflow: hidden;"><img src="/assets/avatar-testimonial.jpg" alt={content.testimonial.name} style="width: 100%; height: 100%; object-fit: cover;" /></div>
            <div>
              <div class="who">{content.testimonial.name}</div>
              <div class="role">{content.testimonial.role}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LOGO STRIP -->
    <section class="section compact cream">
      <div class="container wide">
        <div style="text-align: center; margin-bottom: 28px;">
          <div class="section-eyebrow">{logosSection.eyebrow}</div>
        </div>
        <LogoStrip client:load />
      </div>
    </section>

    <!-- CTA BAND -->
    <CTABand
      client:load
      title={content.cta.title}
      sub={content.cta.subtitle}
      primaryLabel={content.cta.primaryLabel}
      primaryHref={content.cta.primaryHref}
      secondaryLabel={content.cta.secondaryLabel}
      secondaryHref={content.cta.secondaryHref}
    />
  </main>
</BaseLayout>
