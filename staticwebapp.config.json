{
  "routes": [
    {
      "route": "/admin",
      "rewrite": "/admin/index.html"
    },
    {
      "route": "/admin/*",
      "rewrite": "/admin/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-cache",
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
